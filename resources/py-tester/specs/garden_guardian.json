{
  "project": "garden_guardian",
  "title": "Garden Guardian",
  "note": "Runs each script (python3 ftX.py) and checks the exception-handling behaviour the subject pins down. Custom error wording is yours; only the structural markers are checked.",
  "exercises": [
    {
      "id": "ex0",
      "title": "First Exception",
      "file": "ex0/ft_first_exception.py",
      "tests": [
        {
          "name": "valid '25' then invalid 'abc' are both handled, program survives",
          "mode": "script",
          "match": {
            "exit_code": 0,
            "stdout": {
              "type": "in_order",
              "items": ["25", "abc", "All tests completed"]
            }
          }
        }
      ]
    },
    {
      "id": "ex1",
      "title": "Raise Exception",
      "file": "ex1/ft_raise_exception.py",
      "tests": [
        {
          "name": "out-of-range values 100 and -50 are rejected, program survives",
          "mode": "script",
          "match": {
            "exit_code": 0,
            "stdout": {
              "type": "in_order",
              "items": ["25", "abc", "100", "-50", "All tests completed"]
            }
          }
        }
      ]
    },
    {
      "id": "ex2",
      "title": "Different Error Types",
      "file": "ex2/ft_different_errors.py",
      "tests": [
        {
          "name": "demonstrates ValueError, ZeroDivisionError, FileNotFoundError, TypeError",
          "mode": "script",
          "match": {
            "exit_code": 0,
            "stdout": {
              "type": "contains_all",
              "items": [
                "ValueError",
                "ZeroDivisionError",
                "division by zero",
                "FileNotFoundError",
                "TypeError"
              ]
            }
          }
        },
        {
          "name": "operations are demonstrated in order 0..4",
          "mode": "script",
          "match": {
            "exit_code": 0,
            "stdout": {
              "type": "in_order",
              "items": ["operation 0", "operation 1", "operation 2", "operation 3", "operation 4"]
            }
          }
        }
      ]
    },
    {
      "id": "ex3",
      "title": "Custom Error Types",
      "file": "ex3/ft_custom_errors.py",
      "tests": [
        {
          "name": "PlantError / WaterError / GardenError are exercised, program survives",
          "mode": "script",
          "match": {
            "exit_code": 0,
            "stdout": {
              "type": "in_order",
              "items": ["PlantError", "WaterError", "GardenError"]
            }
          }
        }
      ]
    },
    {
      "id": "ex4",
      "title": "Finally Block",
      "file": "ex4/ft_finally_block.py",
      "tests": [
        {
          "name": "cleanup runs on both the happy path and the error path",
          "mode": "script",
          "match": {
            "exit_code": 0,
            "stdout": {
              "type": "in_order",
              "items": ["Opening watering system", "[OK]", "Closing watering system", "PlantError", "Closing watering system"]
            }
          }
        }
      ]
    }
  ]
}
