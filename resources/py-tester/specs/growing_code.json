{
  "project": "growing_code",
  "title": "Growing Code",
  "note": "Checks each function against the behaviour the subject fixes (input -> output). Type hints (ex7) are checked with mypy from the lint menu.",
  "exercises": [
    {
      "id": "ex0",
      "title": "Hello Garden",
      "file": "ex0/ft_hello_garden.py",
      "tests": [
        {
          "name": "prints the welcome message",
          "mode": "func_stdio",
          "func": "ft_hello_garden",
          "args": [],
          "match": { "type": "equals", "expected": "Hello, Garden Community!" }
        }
      ]
    },
    {
      "id": "ex1",
      "title": "Garden Name",
      "file": "ex1/ft_garden_name.py",
      "tests": [
        {
          "name": "echoes the name + fixed status line",
          "mode": "func_stdio",
          "func": "ft_garden_name",
          "stdin": "Community Garden\n",
          "match": {
            "type": "contains_all",
            "items": ["Garden: Community Garden", "Status: Growing well!"]
          }
        }
      ]
    },
    {
      "id": "ex2",
      "title": "Garden Plot Area",
      "file": "ex2/ft_plot_area.py",
      "tests": [
        {
          "name": "5 x 3 -> area 15",
          "mode": "func_stdio",
          "func": "ft_plot_area",
          "stdin": "5\n3\n",
          "match": { "type": "contains_all", "items": ["Plot area: 15"] }
        },
        {
          "name": "7 x 6 -> area 42",
          "mode": "func_stdio",
          "func": "ft_plot_area",
          "stdin": "7\n6\n",
          "match": { "type": "contains_all", "items": ["Plot area: 42"] }
        }
      ]
    },
    {
      "id": "ex3",
      "title": "Harvest Total",
      "file": "ex3/ft_harvest_total.py",
      "tests": [
        {
          "name": "5 + 8 + 3 -> 16",
          "mode": "func_stdio",
          "func": "ft_harvest_total",
          "stdin": "5\n8\n3\n",
          "match": { "type": "contains_all", "items": ["Total harvest: 16"] }
        }
      ]
    },
    {
      "id": "ex4",
      "title": "Plant Age Check",
      "file": "ex4/ft_plant_age.py",
      "tests": [
        {
          "name": "75 days -> ready",
          "mode": "func_stdio",
          "func": "ft_plant_age",
          "stdin": "75\n",
          "match": { "type": "contains_all", "items": ["Plant is ready to harvest!"] }
        },
        {
          "name": "45 days -> needs more time",
          "mode": "func_stdio",
          "func": "ft_plant_age",
          "stdin": "45\n",
          "match": { "type": "contains_all", "items": ["Plant needs more time to grow."] }
        },
        {
          "name": "60 days -> needs more time (strictly > 60)",
          "mode": "func_stdio",
          "func": "ft_plant_age",
          "stdin": "60\n",
          "match": { "type": "contains_all", "items": ["Plant needs more time to grow."] }
        }
      ]
    },
    {
      "id": "ex5",
      "title": "Water Reminder",
      "file": "ex5/ft_water_reminder.py",
      "tests": [
        {
          "name": "4 days -> water",
          "mode": "func_stdio",
          "func": "ft_water_reminder",
          "stdin": "4\n",
          "match": { "type": "contains_all", "items": ["Water the plants!"] }
        },
        {
          "name": "1 day -> fine",
          "mode": "func_stdio",
          "func": "ft_water_reminder",
          "stdin": "1\n",
          "match": { "type": "contains_all", "items": ["Plants are fine"] }
        },
        {
          "name": "2 days -> fine (strictly > 2)",
          "mode": "func_stdio",
          "func": "ft_water_reminder",
          "stdin": "2\n",
          "match": { "type": "contains_all", "items": ["Plants are fine"] }
        }
      ]
    },
    {
      "id": "ex6",
      "title": "Count to Harvest",
      "file": "ex6/ft_count_harvest_iterative.py",
      "extra_files": ["ex6/ft_count_harvest_recursive.py"],
      "tests": [
        {
          "name": "iterative counts 1..5 then harvest",
          "mode": "func_stdio",
          "func": "ft_count_harvest_iterative",
          "stdin": "5\n",
          "match": {
            "type": "in_order",
            "items": ["Day 1", "Day 2", "Day 3", "Day 4", "Day 5", "Harvest time!"]
          }
        }
      ]
    },
    {
      "id": "ex6r",
      "title": "Count to Harvest (recursive)",
      "file": "ex6/ft_count_harvest_recursive.py",
      "tests": [
        {
          "name": "recursive counts 1..5 then harvest",
          "mode": "func_stdio",
          "func": "ft_count_harvest_recursive",
          "stdin": "5\n",
          "match": {
            "type": "in_order",
            "items": ["Day 1", "Day 2", "Day 3", "Day 4", "Day 5", "Harvest time!"]
          }
        }
      ]
    },
    {
      "id": "ex7",
      "title": "Seed Inventory (typed)",
      "file": "ex7/ft_seed_inventory.py",
      "tests": [
        {
          "name": "packets unit",
          "mode": "func_stdio",
          "func": "ft_seed_inventory",
          "args": ["tomato", 15, "packets"],
          "match": { "type": "equals", "expected": "Tomato seeds: 15 packets available" }
        },
        {
          "name": "grams unit",
          "mode": "func_stdio",
          "func": "ft_seed_inventory",
          "args": ["carrot", 8, "grams"],
          "match": { "type": "equals", "expected": "Carrot seeds: 8 grams total" }
        },
        {
          "name": "area unit",
          "mode": "func_stdio",
          "func": "ft_seed_inventory",
          "args": ["lettuce", 12, "area"],
          "match": { "type": "equals", "expected": "Lettuce seeds: covers 12 square meters" }
        },
        {
          "name": "unknown unit",
          "mode": "func_stdio",
          "func": "ft_seed_inventory",
          "args": ["basil", 3, "tons"],
          "match": { "type": "equals", "expected": "Unknown unit type" }
        }
      ]
    }
  ]
}
